---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Brief personal portfolio for data analytics, statistical modeling, and computational projects.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Home">Qiankang Wang</a>
      <a class="contact-link" href="mailto:qkwang98@outlook.com">Contact</a>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f6f8fb;
    --surface: #ffffff;
    --ink: #18212d;
    --muted: #5b6878;
    --line: #d9e1ea;
    --accent: #1268b3;
    --accent-soft: #e8f2fb;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-width: 320px;
    color: var(--ink);
    background: var(--bg);
  }

  a {
    color: inherit;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: min(980px, calc(100% - 36px));
    margin: 0 auto;
    padding: 22px 0;
  }

  .brand,
  .contact-link {
    font-weight: 750;
    text-decoration: none;
  }

  .contact-link {
    color: var(--accent);
  }

  main {
    width: min(980px, calc(100% - 36px));
    margin: 0 auto;
    padding: 36px 0 72px;
  }

  .intro {
    display: grid;
    gap: 18px;
    max-width: 780px;
    padding: 36px 0 30px;
  }

  .eyebrow {
    margin: 0;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3 {
    margin: 0;
    color: var(--ink);
    line-height: 1.12;
    letter-spacing: 0;
  }

  h1 {
    font-size: clamp(2.4rem, 6vw, 4.2rem);
  }

  h2 {
    margin-top: 48px;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
  }

  h3 {
    font-size: 1.22rem;
  }

  p {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .lead {
    font-size: clamp(1.05rem, 2vw, 1.18rem);
  }

  .role {
    color: var(--ink);
    font-size: 1.05rem;
    font-weight: 800;
  }

  .quote {
    color: #33465a;
    font-size: 0.98rem;
    font-style: italic;
  }

  .project-list {
    display: grid;
    gap: 18px;
    margin-top: 22px;
  }

  .project-card {
    display: grid;
    gap: 18px;
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
  }

  .project-card header {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 18px;
  }

  .project-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    color: var(--accent);
    background: var(--accent-soft);
    font-weight: 800;
  }

  .status-pill {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    padding: 6px 10px;
    border: 1px solid #d6b863;
    border-radius: 999px;
    color: #72520f;
    background: #fff8df;
    font-size: 0.82rem;
    font-weight: 800;
    white-space: nowrap;
  }

  .chip-row,
  .link-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 5px 10px;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: #33465a;
    background: #fff;
    font-size: 0.88rem;
    font-weight: 700;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    padding: 8px 12px;
    border: 1px solid var(--accent);
    border-radius: 7px;
    color: #fff;
    background: var(--accent);
    font-weight: 750;
    text-decoration: none;
  }

  .note {
    margin-top: 28px;
    padding-top: 18px;
    border-top: 1px solid var(--line);
    font-size: 0.95rem;
  }

  .page-footer {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 12px;
    margin-top: 36px;
    padding-top: 22px;
    border-top: 1px solid var(--line);
  }

  .page-footer a {
    color: var(--accent);
    font-weight: 750;
    text-decoration: none;
  }

  @media (max-width: 680px) {
    .project-card header {
      display: grid;
    }
  }
</style>

---
import BaseLayout from "../layouts/BaseLayout.astro";

const repoBase = "https://github.com/UrNA1VE/personal-portfolio/tree/master";

const projects = [
  {
    number: "1",
    title: "Hospital Capacity Analytics",
    status: "In progress",
    summary:
      "A synthetic healthcare analytics project showing how patient-flow and capacity data can be generated, transformed, validated, modeled, and presented through dashboard-ready outputs.",
    skills: [
      "Python ETL",
      "Synthetic data generation",
      "dbt SQL models",
      "Data quality checks",
      "Streamlit dashboard",
    ],
    links: [
      {
        label: "Code",
        href: `${repoBase}/demos/healthcare-capacity`,
        variant: "secondary",
      },
      {
        label: "Dashboard",
        href: "https://personal-portfolio-m8pdwmkexj7r3npn4y6mtt.streamlit.app/",
        variant: "primary",
      },
    ],
  },
  {
    number: "2",
    title: "Statistical Modelling",
    summary:
      "A grouped set of graduate projects covering statistical learning, Bayesian modelling, and computational statistics through original reports and code repositories.",
    skills: [
      "Statistical learning",
      "Bayesian MCMC",
      "Model comparison",
      "Model diagnostics",
      "Computational statistics",
      "R Markdown / Notebook",
    ],
    links: [
      {
        label: "Bayesian Analysis",
        href: "https://github.com/UrNA1VE/Bayesian-Zero-Inflated-Generalized-Poisson-Model",
        variant: "primary",
      },
      {
        label: "Statistical Learning",
        href: "https://github.com/UrNA1VE/Vehicle-Insurance-Prediction-MachineLearning",
        variant: "secondary",
      },
      {
        label: "GCR-Project",
        href: `${repoBase}/demos/gcr-computational-analysis`,
        variant: "secondary",
      },
    ],
  },
  {
    number: "3",
    title: "Data Structure & Algorithm",
    summary:
      "A repository for data structure and algorithm practice, including LeetCode-style problem solving and implementation notes.",
    skills: [
      "Data structures",
      "Algorithms",
      "Python",
      "Problem solving",
      "LeetCode",
    ],
    links: [
      {
        label: "Code",
        href: "https://github.com/UrNA1VE/DataStructure-Algorithm",
        variant: "primary",
      },
    ],
  },
];
---

<BaseLayout
  title="Qiankang Wang | Data Analytics Portfolio"
  description="Brief personal portfolio for data analytics, statistical modeling, and computational projects."
>
  <section class="intro">
    <h1>Qiankang Wang</h1>
    <p class="role">Data Analytics | BI | Analytics Engineering</p>
    <p class="quote">"There are no men like me. There's only me." - A Song of Ice and Fire</p>
    <p class="lead">
      Data Analytics and Decision Science professional with expertise delivering SQL-based
      analysis, KPI reporting, and stakeholder-facing decision support across complex operational
      datasets. Hands-on experience working with Oracle Database and SQL Server, with strengths in
      Power BI, Python/R analysis, data validation, and translating business questions into
      reliable insights.
    </p>
    <div class="link-row">
      <a class="project-link" href="https://github.com/UrNA1VE" target="_blank" rel="noreferrer">
        GitHub
      </a>
    </div>
  </section>

  <section aria-labelledby="projects-heading">
    <h2 id="projects-heading">Projects</h2>
    <div class="project-list">
      {
        projects.map((project) => (
          <article class="project-card">
            <header>
              <div>
                <p class="eyebrow">Project {project.number}</p>
                <h3>{project.title}</h3>
              </div>
              {
                project.status ? (
                  <span class="status-pill">{project.status}</span>
                ) : (
                  <span class="project-number" aria-hidden="true">{project.number}</span>
                )
              }
            </header>
            <p>{project.summary}</p>
            <div class="chip-row" aria-label={`${project.title} technical skills`}>
              {project.skills.map((skill) => <span class="chip">{skill}</span>)}
            </div>
            <div class="link-row">
              {
                project.links.map((link) => (
                  <a
                    class:list={["project-link", { secondary: link.variant === "secondary" }]}
                    href={link.href}
                    target="_blank"
                    rel="noreferrer"
                  >
                    {link.label}
                  </a>
                ))
              }
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <footer class="page-footer">
    <p>Portfolio data is synthetic or public-safe.</p>
    <a href="mailto:qkwang98@outlook.com">qkwang98@outlook.com</a>
  </footer>
</BaseLayout>
